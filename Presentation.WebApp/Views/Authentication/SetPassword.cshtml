@using Presentation.WebApp.Models.Authentication.Register
@model SetPasswordForm
@{
    ViewData["Title"] = "Set Password";
    Layout = "Layouts/_AuthLayout";
}

<div class="page__set-password">
    @if (!string.IsNullOrWhiteSpace(ViewData["ErrorMessage"]?.ToString()))
    {
        <div>
            @ViewData["ErrorMessage"]?.ToString()
        </div>
    }
    <section class="section__auth">
        <div class="title">
            <h1>Set Your Password</h1>
            <p>Set a strong password to protect your account. For security reasons, your password must be at least 8 characters long and include uppercase and lowercase letters, numbers, and special characters.</p>
        </div>

        <hr />

        <form id="setPasswordForm" method="post" asp-action="SetPassword" asp-controller="Authentication" novalidate>
            <div class="form-group">
                <label class="form-label" asp-for="Password"></label>
                <input class="form-input" asp-for="Password" value="@Model?.Password" />
                <span asp-validation-for="Password"></span>
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="ConfirmPassword"></label>
                <input class="form-input" asp-for="ConfirmPassword" value="@Model?.ConfirmPassword" />
                <span asp-validation-for="ConfirmPassword"></span>
            </div>
            <button type="submit">Continue</button>
        </form>
    </section>

</div>